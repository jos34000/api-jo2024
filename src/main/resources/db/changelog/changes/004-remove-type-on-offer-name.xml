<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1772984689171-8" author="jocelynsainson">
        <dropForeignKeyConstraint baseTableName="tickets" constraintName="fk937h7hknuc1ptaypyp6eikn03"/>
    </changeSet>
    <changeSet id="1772984689171-9" author="jocelynsainson">
        <dropForeignKeyConstraint baseTableName="offer_features" constraintName="fk_offer_features_on_offer_type"/>
    </changeSet>
    <changeSet id="1772984689171-10" author="jocelynsainson">
        <dropForeignKeyConstraint baseTableName="cart_items" constraintName="fkmmenamaor8jfy1btrw5ge79me"/>
    </changeSet>
    <changeSet id="1772984689171-1" author="jocelynsainson">
        <createTable tableName="offers">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_offers"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DOUBLE">
                <constraints nullable="false"/>
            </column>
            <column name="number_of_tickets" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1772984689171-2" author="jocelynsainson">
        <addColumn tableName="tickets">
            <column name="offer_id" type="BIGINT"/>
        </addColumn>
    </changeSet>
    <changeSet id="1772984689171-3" author="jocelynsainson">
        <addNotNullConstraint columnName="offer_id" tableName="tickets"/>
    </changeSet>
    <changeSet id="1772984689171-4" author="jocelynsainson">
        <addUniqueConstraint columnNames="name" constraintName="uc_offers_name" tableName="offers"/>
    </changeSet>
    <changeSet id="1772984689171-5" author="jocelynsainson">
        <addForeignKeyConstraint baseColumnNames="offer_type_id" baseTableName="cart_items"
                                 constraintName="FK_CART_ITEMS_ON_OFFER_TYPE" referencedColumnNames="id"
                                 referencedTableName="offers"/>
    </changeSet>
    <changeSet id="1772984689171-6" author="jocelynsainson">
        <addForeignKeyConstraint baseColumnNames="offer_id" baseTableName="tickets" constraintName="FK_TICKETS_ON_OFFER"
                                 referencedColumnNames="id" referencedTableName="offers"/>
    </changeSet>
    <changeSet id="1772984689171-7" author="jocelynsainson">
        <addForeignKeyConstraint baseColumnNames="offer_id" baseTableName="offer_features"
                                 constraintName="fk_offer_features_on_offer" referencedColumnNames="id"
                                 referencedTableName="offers"/>
    </changeSet>
    <changeSet id="1772984689171-12" author="jocelynsainson">
        <dropTable cascadeConstraints="true" tableName="offer_types"/>
    </changeSet>
    <changeSet id="1772984689171-13" author="jocelynsainson">
        <dropColumn columnName="offer_type_id" tableName="tickets"/>
    </changeSet>

</databaseChangeLog>