<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="019-add-used-to-reset-token" author="dev">
        <addColumn tableName="password_reset_token">
            <column name="used" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createIndex indexName="idx_reset_token_hashed"
                     tableName="password_reset_token">
            <column name="hashed_token"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
