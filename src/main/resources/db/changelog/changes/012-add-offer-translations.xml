<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="012-add-offer-translations" author="jos">
        <createTable tableName="offer_translations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="offer_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_offer_translations_offer"
                             references="offers(id)"
                             deleteCascade="true"/>
            </column>
            <column name="locale" type="VARCHAR(5)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="features" type="TEXT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="offer_translations"
                columnNames="offer_id, locale"
                constraintName="uq_offer_translations_offer_locale"/>
    </changeSet>

</databaseChangeLog>
